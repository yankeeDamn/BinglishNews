rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read profiles
      allow read: if isSignedIn();
      // Users can create their own profile
      allow create: if isOwner(userId)
                    && request.resource.data.role == "user";
      // Users can update their own profile (but not change role)
      allow update: if isOwner(userId)
                    && request.resource.data.role == resource.data.role;
      // Only admins can change roles
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Posts ──────────────────────────────────────────────────────
    match /posts/{postId} {
      // Public: anyone can read published posts
      allow read: if resource.data.status == "published";
      // Signed-in users can also read their own posts (any status)
      allow read: if isSignedIn() && resource.data.authorId == request.auth.uid;
      // Admins can read all posts
      allow read: if isAdmin();

      // Signed-in users can create posts only with status "pending"
      allow create: if isSignedIn()
                    && request.resource.data.status == "pending"
                    && request.resource.data.authorId == request.auth.uid;

      // Authors can update their own pending posts (but cannot change status)
      allow update: if isSignedIn()
                    && resource.data.authorId == request.auth.uid
                    && resource.data.status == "pending"
                    && request.resource.data.status == "pending";

      // Only admins can moderate (change status to published/rejected)
      allow update: if isAdmin()
                    && (request.resource.data.status == "published"
                        || request.resource.data.status == "rejected");

      // Only admins can delete posts
      allow delete: if isAdmin();
    }
  }
}
